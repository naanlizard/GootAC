#pragma once

// --- Network Configuration ---
// Specify your local WiFi credentials
#define WIFI_SSID     "YOUR_SSID"
#define WIFI_PASS     "YOUR_PASSWORD"

// --- Device Identity ---
// DEVICE_NAME: Human-readable name for this unit (e.g., "Bedroom", "Suite")
// Firmware derives: hostname "GootAC-Bedroom", accessory name "Bedroom AC"
#define DEVICE_NAME    "Bedroom"
#define FW_VERSION     "1.1"

// --- System Behavior ---
// FORCE_HK_START: If true, the HomeKit server will initialize immediately 
// upon boot. If false, initialization waits for a successful handshake 
// with the Mitsubishi AC unit via the CN105 port.
#define FORCE_HK_START false
